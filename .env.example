# Database Configuration (MySQL)
# Esempio: mysql://user:password@host:port/database
DATABASE_URL=mysql://root:password@localhost:3306/trading_bot

# Node Environment
NODE_ENV=production

# Server Port (Render/Railway assegneranno automaticamente una porta)
PORT=3000

# Optional: Analytics (se desideri tracciare le metriche)
VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
VITE_ANALYTICS_WEBSITE_ID=your-website-id

# Optional: Bot Configuration
BOT_PYTHON_PATH=/usr/bin/python3
BOT_WORKING_DIR=/app/trading-bot-ai
