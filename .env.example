# Database configuration
DATABASE_URL=mysql://root:password@localhost:3306/trading_bot

# Node server
NODE_ENV=production
PORT=3000

# Python runtime
BOT_PYTHON_PATH=python
BOT_WORKING_DIR=./trading-bot-ai
BOT_POLL_SECONDS=3

# MT5 / HeroFx credentials
HEROFX_LOGIN=923721
HEROFX_PASSWORD=
HEROFX_SERVER=HeroFx-Trade
HEROFX_SYMBOL=XAUUSD.r
# Optional absolute path to terminal64.exe if MT5 is not auto-detected
# MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
# MT5_BOOT_SECONDS=4

# Asset selection
BOT_SYMBOLS=XAUUSD.r,BTCUSD.r
BACKTEST_SYMBOLS=XAUUSD.r,BTCUSD.r

# Risk and execution
DEFAULT_LOT=
USE_RISK_LOT=true
RISK_PERCENT_PER_TRADE=
MAX_LOT=1
MAX_OPEN_POSITIONS=3
MAX_DAILY_LOSS=100
MAX_TRADES_PER_DAY=30
ORDER_DEVIATION_POINTS=30
SCALPING_SIGNAL_THRESHOLD=4
BACKTEST_YEARS=2
BACKTEST_INITIAL_CAPITAL=10000

# Optional runtime overrides
# MT5_FORCE_SIMULATION=true
# ALLOW_SIMULATION_FALLBACK=false
